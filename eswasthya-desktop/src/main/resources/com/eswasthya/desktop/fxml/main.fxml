<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.eswasthya.desktop.controller.MainController"
      styleClass="root-pane">

    <!-- Sidebar -->
    <VBox styleClass="sidebar" minWidth="230" maxWidth="230" spacing="0">

        <!-- Logo -->
        <HBox styleClass="sidebar-logo" spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="22" right="16" bottom="18" left="16"/></padding>
            <Label text="🫀" style="-fx-font-size: 22px;"/>
            <VBox>
                <Label text="eSwasthya" styleClass="sidebar-app-name"/>
                <Label text="HEALTH PORTAL" styleClass="sidebar-app-sub"/>
            </VBox>
        </HBox>

        <!-- User chip -->
        <HBox styleClass="sidebar-user" spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="10" right="16" bottom="12" left="16"/></padding>
            <Label fx:id="userInitialLabel" styleClass="user-avatar"/>
            <VBox>
                <Label fx:id="userNameLabel" styleClass="sidebar-user-name"/>
                <Label fx:id="userRoleLabel" styleClass="sidebar-user-role"/>
            </VBox>
        </HBox>

        <!-- Navigation -->
        <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS" spacing="2">
            <padding><Insets top="10" right="8" bottom="10" left="8"/></padding>

            <Button fx:id="btnDashboard" text="◈  Dashboard"
                    styleClass="nav-btn" maxWidth="Infinity" onAction="#showDashboard"/>
            <Button fx:id="btnRecords"   text="♡  Health Records"
                    styleClass="nav-btn" maxWidth="Infinity" onAction="#showRecords"/>
            <Button fx:id="btnAlerts"    text="◎  Alerts"
                    styleClass="nav-btn" maxWidth="Infinity" onAction="#showAlerts"/>
            <Button fx:id="btnProfile"   text="◉  Profile"
                    styleClass="nav-btn" maxWidth="Infinity" onAction="#showProfile"/>

            <!-- Admin section -->
            <VBox fx:id="adminSection" spacing="2">
                <Separator style="-fx-padding: 8 0; -fx-background-color: rgba(255,255,255,0.08);"/>
                <Label text="ADMIN" styleClass="nav-section-label"/>
                <Button fx:id="btnAdminStats"   text="⊞  Platform Stats"
                        styleClass="nav-btn" maxWidth="Infinity" onAction="#showAdminStats"/>
                <Button fx:id="btnAdminUsers"   text="⊛  All Users"
                        styleClass="nav-btn" maxWidth="Infinity" onAction="#showAdminUsers"/>
                <Button fx:id="btnAdminRecords" text="⊟  All Records"
                        styleClass="nav-btn" maxWidth="Infinity" onAction="#showAdminRecords"/>
            </VBox>
        </VBox>

        <!-- Logout -->
        <VBox styleClass="sidebar-footer">
            <padding><Insets top="10" right="8" bottom="14" left="8"/></padding>
            <Separator style="-fx-background-color: rgba(255,255,255,0.08); -fx-padding: 0 0 8 0;"/>
            <Button text="↩  Sign out" styleClass="nav-btn,nav-btn-logout"
                    maxWidth="Infinity" onAction="#handleLogout"/>
        </VBox>
    </VBox>

    <!-- Main Content -->
    <StackPane fx:id="contentArea" styleClass="content-area" HBox.hgrow="ALWAYS">
        <padding><Insets top="30" right="36" bottom="30" left="36"/></padding>
    </StackPane>
</HBox>
