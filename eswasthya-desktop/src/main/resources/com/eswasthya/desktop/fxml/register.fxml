<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.eswasthya.desktop.controller.RegisterController"
           styleClass="root-pane" alignment="CENTER">

    <VBox styleClass="auth-form-panel" maxWidth="560" spacing="0" alignment="TOP_CENTER">
        <padding><Insets top="36" right="48" bottom="36" left="48"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 20 0;">
            <Label text="🫀" style="-fx-font-size: 26px;"/>
            <VBox>
                <Label text="eSwasthya" styleClass="brand-title-sm"/>
                <Label text="Create your account" styleClass="form-title-sm"/>
            </VBox>
        </HBox>

        <GridPane hgap="14" vgap="12">
            <padding><Insets bottom="16"/></padding>

            <Label text="Username *"  GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="field-label"/>
            <TextField fx:id="usernameField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                       styleClass="text-field-custom" promptText="john_doe"/>

            <Label text="Full Name *" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="field-label"/>
            <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                       styleClass="text-field-custom" promptText="John Doe"/>

            <Label text="Email *"     GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="field-label"/>
            <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="2"
                       styleClass="text-field-custom" promptText="john@example.com"/>

            <Label text="Password *"  GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="3"
                           styleClass="text-field-custom" promptText="Min 8 characters"/>

            <Label text="Confirm *"   GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="field-label"/>
            <PasswordField fx:id="confirmField" GridPane.columnIndex="1" GridPane.rowIndex="4"
                           styleClass="text-field-custom" promptText="Repeat password"/>

            <Label text="Age"         GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="field-label"/>
            <TextField fx:id="ageField" GridPane.columnIndex="1" GridPane.rowIndex="5"
                       styleClass="text-field-custom" promptText="25"/>

            <Label text="Gender"      GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="field-label"/>
            <ComboBox fx:id="genderCombo" GridPane.columnIndex="1" GridPane.rowIndex="6"
                      maxWidth="Infinity" styleClass="combo-custom"/>

            <Label text="Role *"      GridPane.columnIndex="0" GridPane.rowIndex="7" styleClass="field-label"/>
            <ComboBox fx:id="roleCombo" GridPane.columnIndex="1" GridPane.rowIndex="7"
                      maxWidth="Infinity" styleClass="combo-custom"/>
        </GridPane>

        <Label fx:id="errorLabel"   styleClass="error-label"   wrapText="true"/>
        <Label fx:id="successLabel" styleClass="success-label" wrapText="true"/>

        <HBox alignment="CENTER" style="-fx-padding: 4 0 0 0;">
            <ProgressIndicator fx:id="spinner" prefWidth="20" prefHeight="20"/>
        </HBox>

        <Button fx:id="registerButton" text="Create Account" styleClass="btn-primary"
                maxWidth="Infinity" onAction="#handleRegister" style="-fx-padding: 12;"/>

        <HBox alignment="CENTER" spacing="6" style="-fx-padding: 14 0 0 0;">
            <Label text="Already have an account?" styleClass="text-muted"/>
            <Hyperlink fx:id="loginLink" text="Sign in" styleClass="link" onAction="#handleLoginLink"/>
        </HBox>
    </VBox>
</StackPane>
